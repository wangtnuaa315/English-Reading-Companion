/* pages/profile/profile.wxss */
.page-container { min-height: 100vh; background: #f6f7f8; }
.profile-header { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 40rpx; background: linear-gradient(180deg, #2b7cee 0%, #1d68d8 100%); border-radius: 0 0 40rpx 40rpx; }
.avatar-circle { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 16rpx; border: 4rpx solid rgba(255,255,255,0.3); }
.avatar-icon { font-size: 56rpx; }
.profile-name { font-size: 32rpx; font-weight: 700; color: #ffffff; margin-bottom: 8rpx; }
.profile-desc { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.stats-row { display: flex; align-items: center; justify-content: center; margin: -40rpx 32rpx 24rpx; background: #ffffff; border-radius: 24rpx; padding: 32rpx 0; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08); }
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-number { font-size: 40rpx; font-weight: 700; color: #2b7cee; }
.stat-label { font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }
.stat-divider { width: 2rpx; height: 48rpx; background: #e2e8f0; }
.menu-section { margin: 24rpx 32rpx; background: #ffffff; border-radius: 24rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 28rpx 32rpx; border-bottom: 2rpx solid #f8fafc; }
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #f8fafc; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 28rpx; font-weight: 500; color: #334155; }
.menu-badge { font-size: 22rpx; color: #2b7cee; background: rgba(43,124,238,0.1); padding: 4rpx 16rpx; border-radius: 20rpx; margin-right: 12rpx; }
.menu-arrow { font-size: 36rpx; color: #cbd5e1; }
.version-text { text-align: center; font-size: 22rpx; color: #cbd5e1; margin-top: 40rpx; padding-bottom: 40rpx; }
