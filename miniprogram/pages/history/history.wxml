<!--pages/history/history.wxml-->
<view class="page-container">
  <view class="page-header">
    <text class="page-title">历史记录</text>
    <text class="clear-btn" bindtap="clearAll" wx:if="{{historyList.length > 0}}">清空</text>
  </view>

  <scroll-view class="list-scroll" scroll-y="true">
    <view class="history-list" wx:if="{{historyList.length > 0}}">
      <view class="history-item" wx:for="{{historyList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="item-thumb" wx:if="{{item.imagePath}}">
          <image src="{{item.imagePath}}" mode="aspectFill" class="thumb-img"/>
        </view>
        <view class="item-thumb item-thumb-default" wx:else>
          <text class="thumb-icon">📝</text>
        </view>
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <text class="item-meta">翻译为中文 • {{item.timeDisplay}}</text>
          <text class="item-count">{{item.words.length}} 个单词</text>
        </view>
        <view class="item-actions">
          <view class="delete-btn" catchtap="deleteItem" data-id="{{item.id}}">
            <text class="delete-icon">🗑</text>
          </view>
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{historyList.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无历史记录</text>
      <text class="empty-desc">拍照或上传图片开始翻译吧</text>
    </view>
  </scroll-view>
</view>
