/* pages/history/history.wxss */
.page-container { display: flex; flex-direction: column; min-height: 100vh; background: #f6f7f8; }
.page-header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; }
.page-title { font-size: 40rpx; font-weight: 700; color: #0f172a; }
.clear-btn { font-size: 26rpx; color: #ef4444; font-weight: 500; }
.list-scroll { flex: 1; padding: 0 24rpx; }
.history-list { display: flex; flex-direction: column; gap: 16rpx; }
.history-item { display: flex; align-items: center; padding: 24rpx; background: #ffffff; border-radius: 24rpx; border: 2rpx solid #f1f5f9; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.item-thumb { width: 88rpx; height: 88rpx; border-radius: 16rpx; background: #f1f5f9; overflow: hidden; flex-shrink: 0; }
.thumb-img { width: 100%; height: 100%; }
.item-thumb-default { display: flex; align-items: center; justify-content: center; background: #eff6ff; }
.thumb-icon { font-size: 40rpx; }
.item-info { flex: 1; margin-left: 20rpx; overflow: hidden; }
.item-title { display: block; font-size: 28rpx; font-weight: 600; color: #0f172a; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-meta { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }
.item-count { display: block; font-size: 20rpx; color: #2b7cee; margin-top: 4rpx; }
.item-actions { display: flex; align-items: center; gap: 16rpx; }
.delete-btn { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
.delete-btn:active { background: #fef2f2; }
.delete-icon { font-size: 28rpx; }
.arrow-icon { font-size: 40rpx; color: #cbd5e1; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; opacity: 0.4; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #64748b; margin-bottom: 8rpx; }
.empty-desc { font-size: 24rpx; color: #94a3b8; }
